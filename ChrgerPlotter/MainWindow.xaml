<Window x:Class="ChrgerPlotter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:ChrgerPlotter"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="899" Loaded="Window_Loaded">
    <Grid Background="#FF282828">
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto" Height="117" VerticalAlignment="Top">
            <Grid Height="93" Width="879">
                <Label Content="Battery" HorizontalAlignment="Left" Margin="131,3,0,0" VerticalAlignment="Top" Foreground="White"/>
                <TextBox x:Name="TB_Voltage" HorizontalAlignment="Left" Margin="124,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" MaxHeight="18" IsReadOnly="True" Height="16" Background="{x:Null}" BorderBrush="#FF295AEE" RenderTransformOrigin="0.5,0.5" Foreground="White"/>
                <ComboBox x:Name="CB_Port" HorizontalAlignment="Left" Margin="15,25,0,0" VerticalAlignment="Top" Width="94" SelectionChanged="CB_Port_SelectionChanged" Background="Black" BorderBrush="#FF2B5CAC" Foreground="Black"/>
                <Button x:Name="BTN_Start" Content="Start" HorizontalAlignment="Left" Margin="15,61,0,0" VerticalAlignment="Top" Width="39" IsEnabled="False" Click="BTN_Start_Click" Background="#FF34E34C"/>
                <Button x:Name="BTN_Stop" Content="Stop" HorizontalAlignment="Left" Margin="70,61,0,0" VerticalAlignment="Top" Width="39" IsEnabled="False" Click="BTN_Stop_Click" Background="#FFCB3939"/>
                <Label Content="B1" HorizontalAlignment="Left" Margin="202,3,0,0" VerticalAlignment="Top" Width="29" Foreground="White"/>
                <Label Content="B2" HorizontalAlignment="Left" Margin="249,3,0,0" VerticalAlignment="Top" Width="27" Foreground="White"/>
                <Label Content="B3" HorizontalAlignment="Left" Margin="294,3,0,0" VerticalAlignment="Top" Width="29" Foreground="White"/>
                <Label Content="B4" HorizontalAlignment="Left" Margin="340,3,0,0" VerticalAlignment="Top" Width="28" Foreground="White"/>
                <Label Content="B5" HorizontalAlignment="Left" Margin="384,3,0,0" VerticalAlignment="Top" Width="28" Foreground="White"/>
                <Label Content="B6" HorizontalAlignment="Left" Margin="427,3,0,0" VerticalAlignment="Top" Width="28" Foreground="White"/>
                <TextBox x:Name="TB_C1" HorizontalAlignment="Left" Margin="187,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="47" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_C2" HorizontalAlignment="Left" Margin="234,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="46" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_C3" HorizontalAlignment="Left" Margin="280,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="49" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_C4" HorizontalAlignment="Left" Margin="329,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="45" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_C5" HorizontalAlignment="Left" Margin="374,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="45" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_C6" HorizontalAlignment="Left" Margin="419,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="43" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_R1" HorizontalAlignment="Left" Margin="187,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="47" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_R2" HorizontalAlignment="Left" Margin="234,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="46" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_R3" HorizontalAlignment="Left" Margin="280,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="49" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_R4" HorizontalAlignment="Left" Margin="329,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="45" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_R5" HorizontalAlignment="Left" Margin="374,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="45" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_R6" HorizontalAlignment="Left" Margin="419,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="43" FontSize="10" Height="16" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <Label Content="Percentage" HorizontalAlignment="Left" Margin="533,3,0,0" VerticalAlignment="Top" Foreground="White"/>
                <TextBox x:Name="TB_Percent" HorizontalAlignment="Left" Margin="538,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <Label Content="Capacity" HorizontalAlignment="Left" Margin="607,3,0,0" VerticalAlignment="Top" Foreground="White"/>
                <TextBox x:Name="TB_Capacity" HorizontalAlignment="Left" Margin="607,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <Label Content="Wire" HorizontalAlignment="Left" Margin="487,3,0,0" VerticalAlignment="Top" Width="40" Foreground="White"/>
                <TextBox x:Name="TB_Rwire" HorizontalAlignment="Left" Margin="474,52,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="54" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_Rbat" HorizontalAlignment="Left" Margin="124,54,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Height="16" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <Label Content="Temp" HorizontalAlignment="Left" Margin="679,3,0,0" VerticalAlignment="Top" Foreground="White"/>
                <TextBox x:Name="TB_TempIn" HorizontalAlignment="Left" Margin="669,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_TempOut" HorizontalAlignment="Left" Margin="669,53,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_Energy" HorizontalAlignment="Left" Margin="607,52,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_Power" HorizontalAlignment="Left" Margin="538,52,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_Current" HorizontalAlignment="Left" Margin="474,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="54" MaxHeight="18" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <Label Content="Time" HorizontalAlignment="Left" Margin="743,3,0,0" VerticalAlignment="Top" Foreground="White"/>
                <TextBox x:Name="TB_TimeEllapse" HorizontalAlignment="Left" Margin="733,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <TextBox x:Name="TB_TimeRemaining" HorizontalAlignment="Left" Margin="733,53,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="58" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
                <Label Content="Mode" HorizontalAlignment="Left" Margin="806,3,0,0" VerticalAlignment="Top" Foreground="White"/>
                <TextBox x:Name="TB_Mode" HorizontalAlignment="Left" Margin="796,29,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="73" Height="42" CharacterCasing="Upper" FontWeight="Bold" IsReadOnly="True" Background="{x:Null}" BorderBrush="#FF265BF7" Foreground="White"/>
            </Grid>
        </ScrollViewer>
        <Grid Margin="0,122,0,0">
            <ScottPlot:WpfPlot x:Name="wpfPlot" Grid.ColumnSpan="2" Margin="10,0,10,10" />
        </Grid>

    </Grid>
</Window>
